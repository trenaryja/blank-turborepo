{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": ["esnext"],
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"types": ["bun"]
	},
	"include": ["scripts/**/*"],
	"exclude": ["node_modules", "apps", "packages"]
}
