{
	"name": "blank-turborepo",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"fix": "biome check --write .",
		"check": "tsc && biome check .",
		"make:app": "bun scripts/make-app.ts",
		"get-latest": "bun update --latest --interactive",
		"reinstall": "rm -rf node_modules bun.lock && bun install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.3",
		"turbo": "^2.9.18",
		"typescript": "^6"
	},
	"trustedDependencies": [
		"esbuild",
		"unrs-resolver"
	],
	"packageManager": "bun@1.3.11"
}
